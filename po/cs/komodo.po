#: src/main.cpp:51
#, kde-format
msgctxt "Longer description in about page"
msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>KomoDo je správce úkolů, který využívá specifikaci todo.txt. Analyzuje "
"všechny soubory todo.txt, které tuto specifikaci splňují, a převádí je na "
"přehledný seznam úkolů.</p>"


msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>KomoDo je správca úloh, ktorý používa špecifikáciu todo.txt. Parsuje "
"akékoľvek kompatibilné súbory todo.txt a premení ich na jednoduchý zoznam "
"úloh.</p>"

